<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               CanBeDismissedByTappingOutsideOfPopup="False"
               x:Class="YTCnv.UpdatePopup">

    <Frame BorderColor="Transparent" BackgroundColor="Transparent" Padding="25">
        <Frame BackgroundColor="#4c4c4c" BorderColor="Aqua">
            <VerticalStackLayout Spacing="0">
                <Label x:Name="VersionLabel" FontAttributes="Bold" FontSize="Medium" HorizontalOptions="Center" />

                <Label x:Name="ChangeLog" FontSize="Small" HorizontalOptions="Center" Margin="0,20,0,10"/>

                <HorizontalStackLayout>
                    <CheckBox x:Name="DontShowCheckbox" CheckedChanged="OnCheckboxChanged"/>
                    <Label Text="Don't show again" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Button Text="Open Link" Clicked="OnOpenLinkClicked" BackgroundColor="Grey"/>
                    <Button Text="Later" Clicked="OnCancelClicked" BackgroundColor="Grey"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>
    </Frame>
</toolkit:Popup>
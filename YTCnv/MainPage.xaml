<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YTCnv.MainPage">

    <VerticalStackLayout Padding="25,0" Spacing="25">

        <FlexLayout Padding="0,20,0,25" HeightRequest="100" VerticalOptions="Center">
            <Label Text="Youtube Converter" FontAttributes="Bold" FontSize="20" FlexLayout.Grow="1" FontFamily="Poppins" VerticalOptions="Center"/>
            <Frame Padding="5" VerticalOptions="Center" BackgroundColor="Transparent" BorderColor="Transparent">
                <ImageButton x:Name="YoutubeSearcher" Source="magglass.png" WidthRequest="25" HeightRequest="25" Clicked="OpenSearch"/>
            </Frame>
            <Frame Padding="5,0,0,0" VerticalOptions="Center" BackgroundColor="Transparent" BorderColor="Transparent">
                <ImageButton x:Name="GoToSettings" Source="settings.png" WidthRequest="25" HeightRequest="25" Clicked="OpenSettings"/>
            </Frame>
        </FlexLayout>

        <VerticalStackLayout>
            <Label Text="YouTube URL or ID:" FontAttributes="Bold"/>
            <Entry x:Name="UrlEntry" Placeholder="https://www.youtube.com/watch?v=..." />
        </VerticalStackLayout>

        <FlexLayout VerticalOptions="Center">
            <HorizontalStackLayout x:Name="downloadOptions" FlexLayout.Grow="1" IsVisible="False">
                <Picker x:Name="FormatPicker" Title="Choose format" FontSize="13" SelectedIndexChanged="OnWantedFormatChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>MP3</x:String>
                            <x:String>MP4</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Picker x:Name="qualityPicker" Title="Choose quality" FontSize="13" SelectedIndexChanged="OnQualityChanged"/>
            </HorizontalStackLayout>

            <Button x:Name="LoadButton" Text="Load metadata" Clicked="OnLoadClicked" WidthRequest="100" BackgroundColor="White" TextColor="Black" FlexLayout.Grow="1"/>
            <Button x:Name="DownloadButton" Text="Download" Clicked="OnDownloadClicked" WidthRequest="100" IsVisible="False"/>
            <Button x:Name="CancelButton" Text="Cancel" Clicked="OnCancelClicked" WidthRequest="100" BackgroundColor="White" TextColor="Black" IsVisible="False"/>
        </FlexLayout>

        <VerticalStackLayout HeightRequest="80">
            <ProgressBar x:Name="DwnldProgress" IsVisible="False" />
            <ActivityIndicator x:Name="DownloadIndicator" IsVisible="False" IsRunning="True" />
            <Label x:Name="StatusLabel" IsVisible="False" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <BoxView HeightRequest="1" Color="Aqua" Margin="10,0"/>

        <Frame x:Name="DownloadHistoryFrame" BackgroundColor="#252525" BorderColor="#252525" Padding="15" CornerRadius="20">
            <FlexLayout Direction="Column">
                <Label Text="DOWNLOAD HISTORY" FontFamily="Poppins" HorizontalTextAlignment="Center" FontSize="15"/>

                <Label x:Name="EmptyHistory" Text="History is empty" FlexLayout.Grow="1" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"/>

                <CollectionView ItemsSource="{Binding DownloadHistory}" x:Name="DownloadList" SelectionMode="None" BackgroundColor="Transparent" IsVisible="False">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="12" BackgroundColor="Transparent" BorderColor="Transparent">
                                <Grid VerticalOptions="Center" ColumnDefinitions="*, 15, Auto">
                                    <Label Text="{Binding Title}" VerticalTextAlignment="Center" LineBreakMode="WordWrap" Padding="10,0,0,0" Grid.Column="0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnHistoryItemTapped" CommandParameter="{Binding UrlOrID}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Frame Padding="0" BackgroundColor="Transparent" BorderColor="Transparent" Grid.Column="2">
                                        <ImageButton Source="cross.png"
                                             CommandParameter="{Binding UrlOrID}"
                                             Clicked="OnRemoveHistoryItem"
                                             BackgroundColor="Transparent"
                                             WidthRequest="25" HeightRequest="25"
                                             VerticalOptions="Center"
                                             Margin="0,0,10,0"/>
                                    </Frame>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </FlexLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>

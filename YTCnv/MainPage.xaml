<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YTCnv.MainPage">

    <Grid RowDefinitions="*" ColumnDefinitions="*">
        <VerticalStackLayout Padding="25,0" Spacing="25">

            <FlexLayout Padding="0,20,0,25" HeightRequest="100" VerticalOptions="Center">
                <Label Text="Youtube Converter" FontAttributes="Bold" FontSize="20" FlexLayout.Grow="1" FontFamily="Poppins" VerticalOptions="Center"/>
                <Border Margin="0,4,0,0" Padding="5" VerticalOptions="Start" BackgroundColor="Transparent" Stroke="Transparent" WidthRequest="40" HeightRequest="40">
                    <ImageButton x:Name="YoutubeSearcher" Source="magglass.svg" Clicked="OpenSearch"/>
                </Border>
                <Border Margin="0,8,0,0" Padding="5,0,0,0" VerticalOptions="End" BackgroundColor="Transparent" Stroke="Transparent" WidthRequest="40" HeightRequest="40">
                    <ImageButton x:Name="GoToSettings" Source="settings.svg" Clicked="OpenSettings"/>
                </Border>
            </FlexLayout>

            <VerticalStackLayout>
                <Label Text="YouTube URL or ID:" FontAttributes="Bold"/>
                <Entry x:Name="UrlEntry" Placeholder="https://www.youtube.com/watch?v=..." Text="{Binding UrlEntryText, Mode=TwoWay}"/>
            </VerticalStackLayout>

            <FlexLayout VerticalOptions="Center">
                <HorizontalStackLayout x:Name="downloadOptions" FlexLayout.Grow="1" IsVisible="{Binding DownloadOptionsIsVisible}">
                    <Picker x:Name="FormatPicker" Title="Choose format" FontSize="13" SelectedIndex="{Binding FormatPickerSelectedIndex, Mode=TwoWay}" SelectedIndexChanged="OnWantedFormatChanged" IsEnabled="{Binding FormatPickerIsEnabled}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>MP3</x:String>
                                <x:String>MP4</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Picker x:Name="qualityPicker" Title="Choose quality" FontSize="13" SelectedIndexChanged="OnQualityChanged" SelectedIndex="{Binding QualityPickerSelectedIndex, Mode=TwoWay}" ItemsSource="{Binding QualityPickerItemsSource}" IsVisible="{Binding QualityPickerIsVisible}" IsEnabled="{Binding QualityPickerIsEnabled}"/>
                </HorizontalStackLayout>

                <Button x:Name="LoadButton" Text="Load metadata" Clicked="OnLoadClicked" WidthRequest="100" BackgroundColor="White" TextColor="Black" FlexLayout.Grow="1" IsVisible="{Binding LoadButtonIsVisible}" IsEnabled="{Binding LoadButtonIsEnabled}"/>
                <Button x:Name="DownloadButton" Text="Download" Clicked="OnDownloadClicked" WidthRequest="100" IsVisible="{Binding DownloadButtonIsVisible}"/>
                <Button x:Name="CancelButton" Text="Cancel" Clicked="OnCancelClicked" WidthRequest="100" BackgroundColor="White" TextColor="Black" IsVisible="{Binding CancelButtonIsVisible}"/>
            </FlexLayout>

            <VerticalStackLayout HeightRequest="80">
                <ProgressBar x:Name="DwnldProgress" IsVisible="{Binding DwnldProgressIsVisible}" />
                <ActivityIndicator x:Name="DownloadIndicator" IsVisible="{Binding DownloadIndicatorIsVisible}" IsRunning="True" />
                <Label x:Name="StatusLabel" IsVisible="{Binding StatusLabelIsVisible}" HorizontalTextAlignment="Center" FormattedText="{Binding StatusLabelFormattedText}"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="Aqua" Margin="10,0"/>

            <Frame x:Name="DownloadHistoryFrame" BackgroundColor="#252525" BorderColor="#252525" Padding="15" CornerRadius="20">
                <FlexLayout Direction="Column">
                    <Label Text="DOWNLOAD HISTORY" FontFamily="Poppins" HorizontalTextAlignment="Center" FontSize="15"/>

                    <Label x:Name="EmptyHistory" Text="History is empty" FlexLayout.Grow="1" VerticalTextAlignment="Center" HorizontalTextAlignment="Center"/>

                    <CollectionView ItemsSource="{Binding DownloadHistory}" x:Name="DownloadList" SelectionMode="None" BackgroundColor="Transparent" IsVisible="False">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12,10,12,0" BackgroundColor="Transparent" BorderColor="Transparent">
                                    <Grid VerticalOptions="Center" ColumnDefinitions="*, 15, Auto" RowDefinitions="Auto, Auto">
                                        <Label Text="{Binding Title}" VerticalTextAlignment="Center" LineBreakMode="WordWrap" Padding="10,0,0,0" Grid.Column="0">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnHistoryItemTapped" CommandParameter="{Binding UrlOrID}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Frame Padding="0" BackgroundColor="Transparent" BorderColor="Transparent" Grid.Column="2">
                                            <ImageButton Source="cross.svg"
                                                 CommandParameter="{Binding UrlOrID}"
                                                 Clicked="OnRemoveHistoryItem"
                                                 BackgroundColor="Transparent"
                                                 WidthRequest="25" HeightRequest="25"
                                                 VerticalOptions="Center"
                                                 Margin="0,0,10,0"/>
                                        </Frame>
                                        <BoxView Grid.Row="1" Grid.ColumnSpan="3" HeightRequest="1" Color="Gray" Margin="8,10,8,0"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </FlexLayout>
            </Frame>

        </VerticalStackLayout>

        <Frame x:Name="Popup" BackgroundColor="#80212121" BorderColor="Transparent" CornerRadius="0" HasShadow="False" InputTransparent="False" IsVisible="{Binding PopupIsVisible}">
            <Frame BackgroundColor="{Binding PopupBackground}" BorderColor="Transparent" HorizontalOptions="Center" VerticalOptions="Center" MinimumWidthRequest="200" CornerRadius="12">
                <VerticalStackLayout>
                    <Label Text="{Binding PopupTitle}" FontAttributes="Bold" Padding="0,0,0,20" HorizontalOptions="Center" FontSize="17"/>
                    <Label Text="{Binding PopupMessage}" Padding="0,0,0,5" FontSize="15"/>

                    <Grid RowDefinitions="Auto">
                        <Button Text="{Binding PopupButtonText}" TextColor="#d0d0d0" BackgroundColor="Transparent" HorizontalOptions="End" Padding="1" Clicked="OnClosePopupClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Frame>
    </Grid>
</ContentPage>
